# Domains (production only)
APP_DOMAIN=quest.example.com
AUTH_DOMAIN=auth.example.com

# Postgres
PG_USER=questkeeper
PG_PASS=secretpassword

# Auth (required)
JWT_SECRET=your-random-secret-here
CASDOOR_CLIENT_ID=questkeeper-client
CASDOOR_CLIENT_SECRET=your-casdoor-secret-here

# MinIO (optional)
MINIO_USER=minioadmin
MINIO_PASS=minioadmin

# GlitchTip (error tracking)
GLITCHTIP_SECRET=your-random-secret-here
# Get DSN from GlitchTip project settings after setup
VITE_SENTRY_DSN=

# CORS (optional, defaults to *)
# CORS_ORIGIN=https://your-domain.com

# Cloudflare Tunnel (prod only)
# CF_TUNNEL_TOKEN=your-tunnel-token
